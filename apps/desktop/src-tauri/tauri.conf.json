{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "atlas-desktop",
  "version": "0.1.1",
  "identifier": "com.atlas.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:47292",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Atlas",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/atlas-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "endpoints": [
        "https://github.com/atlas-org/atlas/releases/latest/download/latest.json"
      ],
      "pubkey": "YOUR_PUBKEY_HERE"
    }
  }
}