{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "dialog:default",
    "core:default",
    "fs:default",
    "os:default",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "code",
          "cmd": "code",
          "args": true
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-open"
  ]
}